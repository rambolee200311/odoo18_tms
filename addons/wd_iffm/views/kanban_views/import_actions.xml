    <!-- 打开作业看板卡片视图 -->
    <record id="action_open_workbench_board_card" model="ir.actions.act_window">
        <field name="name">提单作业看板</field>
        <field name="res_model">operation.workbench.card</field>
        <field name="view_mode">kanban</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'kanban', 'view_id': ref('wd_iffm.view_operation_workbench_card_kanban')})]"/>
        <field name="domain">[('active', '=', True)]</field>
        <field name="context">{'group_by': 'lane_id'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无作业数据
            </p>
            <p>
                从提单看板中点击提单卡片进入作业看板
            </p>
        </field>
    </record>

    <record id="action_world_depot_waybill_form_detail" model="ir.actions.act_window">
        <field name="name">作业详情</field>
        <field name="res_model">world.depot.waybill</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="view_id" ref="wd_iffm.view_world_depot_waybill_form"/>
<!--        <field name="context">{'active_id': active_id}</field> -->
    </record>
