<odoo>

    <record id="operation_order_clearance_invoice_line_form_view" model="ir.ui.view">
        <field name="name">operation.order.clearance.invoice.line.form</field>
        <field name="model">operation.order.clearance.invoice.line</field>
        <field name="arch" type="xml">
            <form string="Invoice Line" class="wd_iffm_required_highlight">
                <header>
                    <field name="payment_state" widget="statusbar"
                           statusbar_visible="draft,paying,paid"/>
                    <button name="action_request_clearance_payment"
                            type="object"
                            string="Request Payment"
                            class="btn-primary"
                            invisible="payment_state != 'draft'"/>
                    <button name="action_revoke_payment_request" type="object" string="Revoke Request"
                            class="btn-warning" invisible="payment_state != 'paying' or not vendor_invoice_id"/>

                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="clearance_id" readonly="1"/>
                            <field name="customs_broker_id" required="1" readonly="payment_state!='draft'"
                                   options="{'no_create': True, 'no_open': True}"
                                   domain="[('is_customs_broker','=',True)]"/>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}"
                                   readonly="payment_state != 'draft'"/>
                            <field name="payment_company_id" required="1" readonly="payment_state != 'draft'"
                                   options="{'no_create': True, 'no_open': True}" domain="[('is_payment','=',True)]"/>
                            <field name="receipt_company_id" required="1" readonly="payment_state != 'draft'"
                                   options="{'no_create': True, 'no_open': True}" domain="[('is_receipt','=',True)]"/>

                            <field name="vendor_invoice_id" readonly="1"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="bank_proof_attachment_ids" widget="many2many_binary" readonly="1"/>
                            <field name="apply_user_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="apply_datetime"/>

                        </group>
                        <group>
                            <field name="vendor_invoice_num" required="1"/>
                            <field name="invoice_date" required="1"/>
                            <field name="amount_total" readonly="1" required="1"/>
                            <field name="vendor_invoice_attachment_ids" widget="many2many_binary" required="1"
                                   readonly="payment_state != 'draft'"/>


                            <field name="remark"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cost">
                            <field name="cost_line_ids" readonly="payment_state !='draft'">
                                <list editable="bottom">
                                    <field name="charge_item_id" options="{'no_create': True, 'no_open': True}"
                                           domain="[('operation_type', '=','clearance'),('is_leaf','=',True)]"/>

                                    <field name="qty"/>
                                    <field name="unit_price"/>
                                    <field name="currency_id" required="1"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="cost_nature" required="1"/>
                                    <field name="amount_total"/>
                                    <field name="manual_amount_total"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>
                    </notebook>


                </sheet>
            </form>
        </field>
    </record>


    <!-- Action for Clearance Invoices -->
    <record id="action_operation_order_clearance_invoice_line" model="ir.actions.act_window">
        <field name="name">Invoice Line</field>
        <field name="res_model">operation.order.clearance.invoice.line</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="operation_order_clearance_invoice_line_form_view"/>
        <field name="target">new</field>
    </record>
</odoo>