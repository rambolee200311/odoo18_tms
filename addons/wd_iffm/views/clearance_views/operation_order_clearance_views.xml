<odoo>


    <record id="view_operation_order_clearance_tree" model="ir.ui.view">
        <field name="name">operation.order.clearance.tree</field>
        <field name="model">operation.order.clearance</field>
        <field name="arch" type="xml">
            <list string="Clearance Orders" create="false">
                <field name="name"/>
                <field name="waybill_id"/>
                <field name="project_id"/>
                <field name="shipping_line_id"/>
                <field name="container_qty"/>
                <field name="state" widget="badge" decoration-success="state == 'close'"
                       decoration-primary="state == 'cancelled'"/>
                <field name="eta"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="operation_order_clearance_form_view" model="ir.ui.view">
        <field name="name">operation.order.clearance.form</field>
        <field name="model">operation.order.clearance</field>
        <field name="priority">10</field>
        <field name="arch" type="xml">
            <form string="Clearance" class="wd_iffm_required_highlight" create="false">
                <header>
                    <button name="action_clearancing" type="object" string="Clearancing" class="btn-secondary"
                            invisible="state not in ('open','paying','paid')"/>
                    <button name="action_clearanced" type="object" string="Clearanced" class="btn-secondary"
                            invisible="state != 'clearancing'"/>
                    <button name="action_close" type="object" string="Close" class="btn-success"
                            invisible="state != 'clearanced'"/>
                    <button name="action_open_reclearance_wizard"
                            type="object"
                            string="Back To Paid"
                            class="btn-warning"
                            invisible="(state != 'clearancing') and (parent_id == False)"/>
                    <button name="action_recompute_state" type="object" string="Recompute State"
                            invisible="state in ('clearancing','clearanced','close','cancelled')"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="open,paying,paid,clearancing,clearanced,close"/>

                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_child_clearance"
                                type="object"
                                string="Create Child Clearance"
                                class="oe_stat_button"
                                icon="fa-film"/>

                    </div>

                    <group>
                        <group string="Base Info">
                            <field name="waybill_id" required="1"
                                   readonly="1"/>
                            <!--                            <field name="project_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>-->
                            <field name="container_qty" readonly="state != 'open'"/>
                            <field name="hs_code_qty" required="1" readonly="state in ('clearanced','close')"/>
                            <field name="eu_eori_no" readonly="1"/>
                            <field name="vat_tax_no" readonly="1"/>
                            <field name="clearance_receipt_no" readonly="state in ('clearanced','close')"/>
                            <field name="customs_declaration_datetime"
                                   readonly="state in ('clearancing','clearanced','close')"/>
                            <field name="remark" readonly="state in ('close')"/>


                            <field name="clearance_type" readonly="state in ('clearanced','close')" required="1"/>
                            <field name="customs_release_datetime"
                                   invisible="clearance_type != 'general'" readonly="state in ('clearanced','close')"
                            />


                            <field name="inbound_release_datetime"
                                   invisible="clearance_type !='bonded_in'" readonly="state in ('clearanced','close')"
                            />
                            <field name="outbound_release_datetime"
                                   invisible="clearance_type != 'bonded_out'" readonly="state in ('clearanced','close')"

                            />

                            <field name="t1_closed_datetime"
                                   invisible="clearance_type != 't1_transit'" readonly="state in ('clearanced','close')"
                            />
                            <field name="t1_inbound_release_datetime"
                                   invisible="clearance_type != 't1_bonded'" readonly="state in ('clearanced','close')"
                            />
                        </group>
                        <group string="Clearance Info">
                            <field name="is_clearance_overdue" readonly="1" invisible="1"/>
                            <field name="overdue_blocking_reason_id" required="is_clearance_overdue"
                                   invisible="is_clearance_overdue == False"/>
                            <field name="overdue_reason_note"
                                   required="overdue_blocking_reason_id and overdue_blocking_reason_short_name == 'Others + Exp'"
                                   invisible="not (overdue_blocking_reason_id and overdue_blocking_reason_short_name == 'Others + Exp')"/>

                            <field name="overdue_handle_result" required="is_clearance_overdue"
                                   invisible="is_clearance_overdue == False"/>
                            <field name="overdue_result_note"
                                   required="overdue_handle_result == 'other'"
                                   invisible="overdue_handle_result != 'other'"/>
                        </group>
                    </group>
                    <notebook>
                        <!-- Tab 1: Charge / Cost -->
                        <page string="Charge / Cost">

                            <field name="invoice_line_ids" context="{'default_clearance_id': id}"
                                   readonly="state in ('close')">
                                <list>

                                    <field name="vendor_invoice_id"/>
                                    <field name="invoice_date"/>
                                    <field name="amount_total"/>
                                    <field name="payment_state"/>
                                </list>
                            </field>


                            <!-- Charge Lines -->
                            <group string="Charges" invisible="state not in ('close','clearancing','clearanced')">
                                <field name="charge_line_ids" readonly="state in ('clearanced','close')">
                                    <list editable="bottom">
                                        <field name="charge_qty" column_invisible="True"/>
                                        <field name="charge_item_id" options="{'no_create': True, 'no_open': True}"
                                               domain="[('operation_type', '=','clearance'),('is_leaf','=',True)]"
                                               required="1"/>
                                        <field name="is_fixed_fee" readonly="1"/>
                                        <field name="qty" readonly="is_fixed_fee"/>
                                        <field name="unit_price" readonly="is_fixed_fee"/>
                                        <field name="amount_total" sum="Total Amount"/>
                                        <field name="manual_amount_total" sum="Manual Total"/>
                                        <field name="remark"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Containers">
                            <field name="clearance_container_ids" create="False" delete="False"
                                   readonly="state in ('clearancing','clearanced','close')">
                                <list editable="bottom" create="False" delete="False">
                                    <field name="container_number"/>
                                    <field name="container_type"/>
                                    <field name="weight"/>
                                </list>
                            </field>
                        </page>
                        <!-- Tab 2: Documents -->
                        <page string="Documents">
                            <field name="attachment_line_ids" readonly="state in ('clearanced','close')">
                                <list editable="bottom">
                                    <field name="doc_type"/>
                                    <field name="name"/>
                                    <field name="file"/>
                                    <field name="upload_time"/>
                                    <field name="upload_user_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_operation_order_clearance_child_form" model="ir.ui.view">
        <field name="name">operation.order.clearance.child.form</field>
        <field name="model">operation.order.clearance</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="Child Clearance" duplicate="false" create="false">
                <header>
                    <button name="action_close" type="object" string="Close" class="btn-success"
                            invisible="state == 'close'"/>
                    <button name="action_recompute_state" type="object" string="Recompute State"
                            invisible="state == 'close'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,paying,paid,close"/>

                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                            <span class="text-muted" invisible="parent_id == False">
                                (Child Clearancce)
                            </span>
                        </h1>
                    </div>

                    <group>
                        <group string="Base Info">
                            <field name="waybill_id" required="1"
                                   readonly="1"/>
                            <field name="parent_id" readonly="1"
                                   context="{'form_view_ref': 'wd_iffm.operation_order_clearance_form_view'}"/>
                            <!--                            <field name="project_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>-->
                            <field name="container_qty" readonly="1"/>
                            <field name="hs_code_qty" required="1" readonly="1"/>
                            <field name="clearance_type" readonly="1"/>
                            <field name="eu_eori_no" readonly="1"/>
                            <field name="vat_tax_no" readonly="1"/>

                            <field name="customs_release_datetime"
                                   invisible="clearance_type != 'general'" readonly="1"/>


                            <field name="inbound_release_datetime"
                                   invisible="clearance_type !='bonded_in'" readonly="1"/>

                            <field name="outbound_release_datetime"
                                   invisible="clearance_type != 'bonded_out'" readonly="1"/>

                            <field name="t1_closed_datetime"
                                   invisible="clearance_type != 't1_transit'" readonly="1"/>
                            <field name="t1_inbound_release_datetime"
                                   invisible="clearance_type != 't1_bonded'" readonly="1"/>
                            <field name="extra_reason"
                                   invisible="parent_id == False"
                                   required="parent_id != False"/>

                            <field name="actual_datetime"
                                   invisible="parent_id == False"
                                   required="parent_id != False"/>

                            <field name="extra_remark"
                                   invisible="extra_reason != 'other'"
                                   required="extra_reason == 'other'"/>
                            <field name="remark" readonly="state=='close'"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Tab 1: Charge / Cost -->
                        <page string="Charge / Cost">

                            <field name="invoice_line_ids" context="{'default_clearance_id': id}"
                                   readonly="state == 'close'">
                                <list>

                                    <field name="vendor_invoice_id"/>
                                    <field name="invoice_date"/>
                                    <field name="amount_total"/>
                                    <field name="payment_state"/>
                                </list>
                            </field>


                            <!-- Charge Lines -->
                            <group string="Charges">
                                <field name="charge_line_ids" readonly="state == 'close'">
                                    <list editable="bottom">
                                        <field name="charge_qty"/>
                                        <field name="charge_item_id" options="{'no_create': True, 'no_open': True}"
                                               domain="[('operation_type', '=','clearance'),('is_leaf','=',True)]"
                                               required="1"/>
                                        <field name="qty"/>
                                        <field name="unit_price"/>
                                        <field name="amount_total" sum="Total Amount"/>
                                        <field name="manual_amount_total" sum="Manual Total"/>
                                        <field name="remark"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Containers">
                            <field name="clearance_container_ids" readonly="1">
                                <list>
                                    <field name="container_number"/>
                                    <field name="container_type"/>
                                    <field name="weight"/>
                                </list>
                            </field>
                        </page>
                        <!-- Tab 2: Documents -->
                        <page string="Documents">
                            <field name="attachment_line_ids" readonly="1">
                                <list editable="bottom">
                                    <field name="file"/>
                                    <field name="doc_type"/>
                                    <field name="name"/>
                                    <field name="upload_time"/>
                                    <field name="upload_user_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>


    <record id="view_operation_order_child_clearance_search" model="ir.ui.view">
        <field name="name">operation.order.child.clearance.search</field>
        <field name="model">operation.order.clearance</field>
        <field name="arch" type="xml">
            <search>
                <filter string="Group By Parent"
                        name="group_by_parent"
                        context="{'group_by': 'parent_id'}"/>
            </search>
        </field>
    </record>
    <record id="action_operation_order_clearance" model="ir.actions.act_window">
        <field name="name">Clearance Orders</field>
        <field name="res_model">operation.order.clearance</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('parent_id', '=', False)]</field>
        <field name="view_ids" eval="[
        (5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('view_operation_order_clearance_tree')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('operation_order_clearance_form_view')})
    ]"/>

        <field name="context">{'default_state': 'open'}</field>
    </record>
    <record id="operation_order_child_clearance_action" model="ir.actions.act_window">
        <field name="name">Child Clearance Orders</field>
        <field name="res_model">operation.order.clearance</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_operation_order_child_clearance_search"/>
        <field name="context">{'search_default_group_by_parent': 1}</field>
        <field name="domain">[('parent_id', '!=', False)]</field>
        <field name="view_ids" eval="[
        (5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('view_operation_order_clearance_tree')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_operation_order_clearance_child_form')})
    ]"/>
    </record>

    <menuitem id="menu_operation_order_clearance_invoices" name="Clearance"
              parent="menu_operation_handover_root" action="action_operation_order_clearance" sequence="20"/>
    <menuitem id="menu_operation_order_clearance_child_invoices" name="Child Clearance"
              parent="menu_operation_handover_root" action="operation_order_child_clearance_action" sequence="21"/>
</odoo>


