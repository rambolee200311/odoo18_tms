
<odoo>

<record id="view_clearance_reclearance_wizard_form" model="ir.ui.view">
    <field name="name">clearance.reclearance.wizard.form</field>
    <field name="model">clearance.reclearance.wizard</field>
    <field name="arch" type="xml">
        <form string="Re-Clearance" duplicate="false">
            <sheet>
                <group>
<!--                    <field name="clearance_id" readonly="1"/>-->
                    <field name="reason" required="1"/>
                </group>
            </sheet>
            <footer>
                <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
</odoo>