<?xml version="1.0" encoding="utf-8"?>
 <odoo>
     <record id="view_tlmp_transport_order_tree" model="ir.ui.view">
         <field name="name">tlmp.transport.order.tree</field>
         <field name="model">tlmp.transport.order</field>
         <field name="arch" type="xml">
             <list string="Transport Orders" default_order="id desc">
                 <field name="name"/>
                 <field name="source_type" widget="badge" decoration-success="source_type == 'plan_driven'"
                        decoration-info="source_type == 'commercial'"/>
                 <field name="transport_type"/>
                 <field name="partner_id" optional="show"/>
                 <field name="carrier_id" optional="show"/>
                 <field name="state" widget="badge" decoration-success="state == 'confirmed'"
                        decoration-info="state in ('assigned','in_transit')"
                        decoration-warning="state in ('delivered','signed')"
                        decoration-muted="state in ('closed','cancelled')"/>
                 <field name="planned_pickup_date" optional="show"/>
                 <field name="request_id" optional="show"/>
                 <field name="pickup_plan_id" optional="show"/>
                 <field name="quote_id" optional="show"/>
             </list>
         </field>
     </record>
 
     <record id="view_tlmp_transport_order_form" model="ir.ui.view">
         <field name="name">tlmp.transport.order.form</field>
         <field name="model">tlmp.transport.order</field>
         <field name="arch" type="xml">
             <form string="Transport Order">
                 <header>
                     <field name="source_type" widget="badge" class="mx-2"/>
                     <button name="action_confirm" type="object" string="Confirm" invisible="state != 'draft'"
                             class="btn-primary"/>
                     <button name="action_assign" type="object" string="Assign Carrier" invisible="state != 'confirmed'"/>
                     <button name="action_start_transit" type="object" string="Start Transit"
                             invisible="state != 'assigned'"/>
                     <button name="action_deliver" type="object" string="Mark Delivered" invisible="state != 'in_transit'"/>
                     <button name="action_confirm_pod" type="object" string="Confirm POD" invisible="state != 'delivered'"/>
                     <button name="action_bill" type="object" string="Bill" invisible="state != 'signed'"/>
                     <button name="action_settle" type="object" string="Settle" invisible="state != 'billed'"/>
                     <button name="action_close" type="object" string="Close" invisible="state != 'settled'"/>
                     <button name="action_cancel" type="object" string="Cancel"
                             invisible="state not in ('draft', 'confirmed', 'assigned')"/>
                     <field name="state" widget="statusbar"
                            statusbar_visible="draft,confirmed,assigned,in_transit,delivered,signed,billed,settled,closed"/>
                 </header>
                 <sheet>
                     <group>
                         <group string="Order Info">
                             <field name="name" readonly="1"/>
                             <field name="transport_type"/>
                             <field name="fleet_operation_mode"/>
                             <field name="partner_id" options="{'no_create': True}"/>
                             <field name="carrier_id" options="{'no_create': True}"/>
                         </group>
                         <group string="Source Documents">
                             <field name="request_id" options="{'no_open': False, 'no_create': True}"
                                    invisible="not request_id"/>
                             <field name="pickup_plan_id" options="{'no_open': False, 'no_create': True}"
                                    invisible="not pickup_plan_id"/>
                             <field name="inquiry_id" options="{'no_open': False, 'no_create': True}"
                                    invisible="not inquiry_id"/>
                             <field name="quote_id" options="{'no_open': False, 'no_create': True}"
                                    invisible="not quote_id"/>
                         </group>
                     </group>
                     <group string="Schedule &amp; Execution">
                         <group>
                             <field name="planned_pickup_date"/>
                             <field name="planned_delivery_date"/>
                             <field name="actual_pickup_date" readonly="1"/>
                             <field name="actual_delivery_date" readonly="1"/>
                         </group>
                         <group>
                             <field name="driver_name"/>
                             <field name="driver_phone"/>
                             <field name="vehicle_plate"/>
                             <field name="carrier_contact"/>
                             <field name="carrier_phone"/>
                         </group>
                     </group>
                     <notebook>
                         <page string="Cargo" name="cargo_page">
                             <group>
                                 <group>
                                     <field name="cargo_description"/>
                                     <field name="cargo_weight"/>
                                     <field name="cargo_volume"/>
                                     <field name="pallet_count"/>
                                     <field name="package_count"/>
                                 </group>
                                 <group string="Dangerous Goods">
                                     <field name="has_dangerous_goods"/>
                                     <field name="adr_un_number" invisible="not has_dangerous_goods"/>
                                     <field name="adr_class" invisible="not has_dangerous_goods"/>
                                     <field name="adr_packing_group" invisible="not has_dangerous_goods"/>
                                     <field name="adr_tunnel_code" invisible="not has_dangerous_goods"/>
                                 </group>
                             </group>
                         </page>
                         <page string="Containers" name="container_page"
                               invisible="source_type != 'plan_driven'">
                             <field name="container_ids">
                                 <list editable="bottom">
                                     <field name="name"/>
                                     <field name="container_type"/>
                                     <field name="seal_number"/>
                                     <field name="cargo_weight_kg"/>
                                 </list>
                             </field>
                         </page>
                         <page string="Pricing" name="pricing_page">
                             <group>
                                 <field name="price_source"/>
                                 <field name="total_carrier_cost"/>
                                 <field name="total_customer_charge"/>
                                 <field name="source_amount_carrier" readonly="1"/>
                                 <field name="source_amount_customer" readonly="1"/>
                                 <field name="total_base_fee"/>
                                 <field name="total_surcharge"/>
                             </group>
                             <group string="Surcharges">
                                 <field name="surcharge_ids"/>
                             </group>
                         </page>
                         <page string="Documents" name="docs_page">
                             <group>
                                 <field name="pod_id" options="{'no_open': False, 'no_create': True}"/>
                                 <field name="cmr_ids">
                                     <list>
                                         <field name="name"/>
                                         <field name="state"/>
                                     </list>
                                 </field>
                             </group>
                         </page>
                         <page string="Customs" name="customs_page">
                             <group>
                                 <field name="customs_transit_ref"/>
                                 <field name="t1_state"/>
                                 <field name="customs_declaration_ref"/>
                             </group>
                         </page>
                         <page string="Notes" name="notes_page">
                             <field name="notes"/>
                         </page>
                     </notebook>
                 </sheet>
                 <chatter/>
             </form>
         </field>
     </record>
 
     <record id="view_tlmp_transport_order_search" model="ir.ui.view">
         <field name="name">tlmp.transport.order.search</field>
         <field name="model">tlmp.transport.order</field>
         <field name="arch" type="xml">
             <search string="Search Transport Orders">
                 <field name="name"/>
                 <field name="partner_id"/>
                 <field name="carrier_id"/>
                 <field name="request_id"/>
                 <field name="pickup_plan_id"/>
                 <separator/>
                 <filter string="Plan-Driven" name="plan_driven"
                         domain="[('source_type', '=', 'plan_driven')]"/>
                 <filter string="Commercial" name="commercial"
                         domain="[('source_type', '=', 'commercial')]"/>
                 <separator/>
                 <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                 <filter string="In Transit" name="in_transit"
                         domain="[('state', 'in', ('confirmed','assigned','in_transit'))]"/>
                 <filter string="Delivered" name="delivered"
                         domain="[('state', 'in', ('delivered','signed'))]"/>
                 <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                 <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                 <group expand="0" string="Group By">
                     <filter string="Source Type" name="group_source"
                             context="{'group_by': 'source_type'}"/>
                     <filter string="Status" name="group_state"
                             context="{'group_by': 'state'}"/>
                     <filter string="Transport Type" name="group_type"
                             context="{'group_by': 'transport_type'}"/>
                 </group>
             </search>
         </field>
     </record>
 
     <record id="action_tlmp_order" model="ir.actions.act_window">
         <field name="name">Transport Orders</field>
         <field name="res_model">tlmp.transport.order</field>
         <field name="view_mode">list,form</field>
         <field name="search_view_id" ref="view_tlmp_transport_order_search"/>
     </record>
 
 </odoo>
