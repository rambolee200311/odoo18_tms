<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_container_service_request_list" model="ir.ui.view">
        <field name="name">container.service.request.list</field>
        <field name="model">container.service.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="request_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_container_service_request_form" model="ir.ui.view">
        <field name="name">container.service.request.form</field>
        <field name="model">container.service.request</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="request_type"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_container_service_request" model="ir.actions.act_window">
        <field name="name">Container Service Requests</field>
        <field name="res_model">container.service.request</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
