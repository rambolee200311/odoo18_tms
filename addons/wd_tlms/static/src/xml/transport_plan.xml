<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="transport_logistics_management.TransportPlanTemplate" owl="1">
        <div class="o_transport_plan_container">
            <div class="o_transport_plan_header"><h2>运输计划排期</h2></div>
            <div class="o_transport_plan_content">
                <div class="o_container_list_panel">
                    <div class="o_panel_header">
                        <div><h4>待安排集装箱</h4><span class="badge bg-secondary" t-esc="state.containers.length"/></div>
                        <button type="button" class="btn btn-sm btn-primary" t-on-click="openContainerForm">+ 添加集装箱</button>
                    </div>
                    <div class="o_filter_bar">
                        <select class="form-select form-select-sm" t-on-change="onBlNoChange" t-att-value="state.selectedBlNo">
                            <option value="">全部提单</option>
                            <t t-foreach="state.blNoOptions" t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value" t-att-selected="state.selectedBlNo === opt.value" t-esc="opt.label"/>
                            </t>
                        </select>
                        <select class="form-select form-select-sm" t-on-change="onWarehouseChange">
                            <option value="">全部仓库</option>
                            <t t-foreach="state.warehouseOptions" t-as="opt" t-key="opt.value">
                                <option t-att-value="opt.value" t-att-selected="state.selectedWarehouseId === opt.value" t-esc="opt.label"/>
                            </t>
                        </select>
                        <button class="btn btn-link btn-sm text-danger o_clear_btn" t-if="state.selectedBlNo || state.selectedWarehouseId" t-on-click="clearFilters">清空筛选</button>
                    </div>
                    <div class="o_container_list" t-on-dragover.prevent="" t-on-drop="(ev) => onContainerListDrop(ev)">
                        <t t-if="getFilteredContainers().length === 0">
                            <div class="o_empty_state"><p>暂无待安排集装箱</p></div>
                        </t>
                        <t t-else="">
                            <t t-foreach="getFilteredContainers()" t-as="c" t-key="c.id">
                                <div class="o_container_card" draggable="true"
                                     t-att-data-container-id="c.id"
                                     t-on-dragstart="(ev) => onDragStart(ev, c.id)">
                                    <div class="o_container_info">
                                        <div class="o_container_no"><strong t-esc="c.container_no || ''"/></div>
                                        <div class="o_container_details">
                                            <span>提单号：<t t-esc="c.bl_no || ''"/></span>
                                            <span t-if="c.container_type">箱型：<t t-esc="c.container_type"/></span>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>
                <div class="o_calendar_panel">
                    <div class="o_calendar_header">
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="() => changeMonth(-1)">← 上个月</button>
                        <h4 class="o_month_title" t-esc="formatMonthYear()"/>
                        <button class="btn btn-sm btn-outline-secondary" t-on-click="() => changeMonth(1)">下个月 →</button>
                    </div>
                    <div class="o_calendar_grid">
                        <div class="o_calendar_weekdays">
                            <div class="o_weekday">日</div><div class="o_weekday">一</div><div class="o_weekday">二</div>
                            <div class="o_weekday">三</div><div class="o_weekday">四</div><div class="o_weekday">五</div><div class="o_weekday">六</div>
                        </div>
                        <div class="o_calendar_days">
                            <t t-foreach="state.calendarDays" t-as="day" t-key="day.key">
                                <div t-if="day.isEmpty" class="o_calendar_day_empty"/>
                                <div t-else=""
                                     class="o_calendar_day"
                                     t-att-class="getDayClass(day)"
                                     t-att-data-date="day.dateStr"
                                     t-on-dragover.prevent=""
                                     t-on-drop="(ev) => onDrop(ev, day.dateStr)">
                                    <div class="o_day_header">
                                        <span class="o_day_number" t-esc="day.date"/>
                                        <span class="o_day_count badge" t-if="getDayPlans(day.dateStr).count > 0" t-esc="getDayPlans(day.dateStr).count"/>
                                    </div>
                                    <div class="o_day_containers">
                                        <t t-foreach="getDayPlans(day.dateStr).containers" t-as="p" t-key="p.id">
                                            <div class="o_day_container_item" draggable="true"
                                                 t-on-dragstart="(ev) => onPlanDragStart(ev, p.id, p.container_id?.[0], day.dateStr)">
                                                <t t-esc="p.container_no || ''"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
