<odoo>
    <record id="module_category_import_management" model="ir.module.category">
        <field name="name">Import Management</field>
        <field name="description">Import Management</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_customs_specialist" model="res.groups">
        <field name="name">Customs Specialist User</field>
        <field name="category_id" ref="wd_iffm.module_category_import_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

      <record id="rule_project_by_allowed_user" model="ir.rule">
        <field name="name">Project by allowed user</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="domain_force">[('allowed_user_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
          <field name="perm_read" eval="True"/>
          <field name="perm_write" eval="True"/>
          <field name="perm_create" eval="True"/>
          <field name="perm_unlink" eval="True"/>
    </record>
    <record id="waybill_rule_by_project_user" model="ir.rule">
    <field name="name">Waybill by project user</field>
    <field name="model_id" ref="wd_iffm.model_world_depot_waybill"/>
    <field name="domain_force">[('project', '!=', False), ('project.allowed_user_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    <field name="perm_read" eval="1"/>
    <field name="perm_write" eval="1"/>
    <field name="perm_create" eval="1"/>
    <field name="perm_unlink" eval="1"/>
</record>


     <record id="rule_handover_by_project_allowed_user" model="ir.rule">
        <field name="name">Handover by project allowed user</field>
        <field name="model_id" ref="wd_iffm.model_operation_order_handover"/>
        <field name="domain_force">[('project_id.allowed_user_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
        <record id="rule_clearance_by_project_allowed_user" model="ir.rule">
        <field name="name">Clearance by project allowed user</field>
        <field name="model_id" ref="wd_iffm.model_operation_order_clearance"/>
        <field name="domain_force">[('project_id.allowed_user_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
        <record id="rule_statement_period_by_project_allowed_user" model="ir.rule">
        <field name="name">Statement Period by project allowed user</field>
        <field name="model_id" ref="wd_iffm.model_statement_period"/>
        <field name="domain_force">[('project_id.allowed_user_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>



