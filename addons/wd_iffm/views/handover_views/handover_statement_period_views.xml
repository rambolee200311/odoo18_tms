<odoo>
    <record id="view_handover_statement_period_form" model="ir.ui.view">
        <field name="name">handover.statement.period.form</field>
        <field name="model">operation.order.handover</field>
        <field name="arch" type="xml">
            <form string="Handover Charge Details">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="waybill_id" readonly="1"/>
                        <field name="container_nums"/>
                        <field name="currency_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                        <field name="amount_total_change"/>
                        <field name="manual_amount_total_change" readonly="statement_period_id_state =='expense_confirmed'"/>
                    </group>
                    <group string="Charges">
                        <field name="charge_line_ids" readonly="1"
                               context="{'tree_view_ref': 'wd_iffm.view_operation_order_handover_charge_line_list'}" mode="list">
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_operation_order_handover_charge_line_list" model="ir.ui.view">
        <field name="name">operation.order.handover.charge.line.list</field>
        <field name="model">operation.order.handover.charge.line</field>
        <field name="arch" type="xml">
            <list create="false" delete="false" editable="top">
                <field name="charge_item_id" options="{'no_create': True, 'no_open': True}"
                       domain="[('operation_type', '=', 'handover'), ('is_leaf', '=', True)]" required="1"/>
                <field name="qty"/>
                <field name="unit_price"/>
                <field name="amount_total"/>
                <field name="manual_amount_total"/>
                <field name="remark"/>
            </list>
        </field>
    </record>
