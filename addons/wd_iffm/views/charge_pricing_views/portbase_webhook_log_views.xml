<odoo>
        <!-- List -->
        <record id="view_portbase_webhook_log_list" model="ir.ui.view">
            <field name="name">portbase.webhook.log.list</field>
            <field name="model">portbase.webhook.log</field>
            <field name="arch" type="xml">
                <list>
                    <field name="received_at"/>
                    <field name="process_status"/>
                    <field name="event_type"/>
                    <field name="event_id"/>
                    <field name="tracking_id"/>
                    <field name="bl_number"/>
                    <field name="reference_number"/>
                    <field name="request_ip"/>
                </list>
            </field>
        </record>

        <!-- Form -->
        <record id="view_portbase_webhook_log_form" model="ir.ui.view">
            <field name="name">portbase.webhook.log.form</field>
            <field name="model">portbase.webhook.log</field>
            <field name="arch" type="xml">
                <form string="Portbase Webhook Log" duplicate="false">
                    <sheet>
                        <group col="2">
                            <group col="2">
                                <field name="received_at" readonly="1"/>
                                <field name="process_status" readonly="1"/>
                                <field name="event_type" readonly="1"/>
                                <field name="event_id" readonly="1"/>
                                <field name="tracking_id" readonly="1"/>
                                <field name="bl_number" readonly="1"/>
                                <field name="reference_number" readonly="1"/>
                                <field name="request_ip" readonly="1"/>
                            </group>
                            <group col="2">
                                <field name="process_message" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Headers">
                                <field name="request_headers" readonly="1"/>
                            </page>
                            <page string="Payload">
                                <field name="raw_payload" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search -->
        <record id="view_portbase_webhook_log_search" model="ir.ui.view">
            <field name="name">portbase.webhook.log.search</field>
            <field name="model">portbase.webhook.log</field>
            <field name="arch" type="xml">
                <search>
                    <field name="event_id"/>
                    <field name="tracking_id"/>
                    <field name="bl_number"/>
                    <field name="event_type"/>
                    <field name="process_status"/>
                    <field name="received_at"/>
                    <filter name="filter_new" string="New" domain="[('process_status', '=', 'new')]"/>
                    <filter name="filter_done" string="Done" domain="[('process_status', '=', 'done')]"/>
                    <filter name="filter_error" string="Error" domain="[('process_status', '=', 'error')]"/>
                </search>
            </field>
        </record>



        <!-- Action -->
        <record id="action_portbase_webhook_log" model="ir.actions.act_window">
            <field name="name">Portbase Webhook Logs</field>
            <field name="res_model">portbase.webhook.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_portbase_webhook_log_search"/>
        </record>

        <!-- Menu -->
        <menuitem id="menu_portbase_webhook_log"
                  name="Portbase Webhook Logs"
                  parent="waybill_logi_menu"
                  action="action_portbase_webhook_log"
                  groups="base.group_system"
                  sequence="804"/>

</odoo>
