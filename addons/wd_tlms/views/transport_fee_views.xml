 <?xml version="1.0" encoding="utf-8"?>
 <odoo>
 
     <!-- ============================================================
          Fee Type - Tree + Form + Search
          ============================================================ -->
     <record id="view_transport_fee_type_tree" model="ir.ui.view">
         <field name="name">transport.fee.type.tree</field>
         <field name="model">transport.fee.type</field>
         <field name="arch" type="xml">
             <list string="Fee Types" default_order="name">
                 <field name="name"/>
                 <field name="code"/>
                 <field name="category"/>
                 <field name="active"/>
             </list>
         </field>
     </record>
 
     <record id="view_transport_fee_type_form" model="ir.ui.view">
         <field name="name">transport.fee.type.form</field>
         <field name="model">transport.fee.type</field>
         <field name="arch" type="xml">
             <form string="Fee Type">
                 <sheet>
                     <group>
                         <group>
                             <field name="name"/>
                             <field name="code"/>
                             <field name="category"/>
                             <field name="active"/>
                         </group>
                         <group>
                             <field name="description"/>
                         </group>
                     </group>
                 </sheet>
             </form>
         </field>
     </record>
 
     <record id="view_transport_fee_type_search" model="ir.ui.view">
         <field name="name">transport.fee.type.search</field>
         <field name="model">transport.fee.type</field>
         <field name="arch" type="xml">
             <search>
                 <field name="name"/>
                 <field name="code"/>
                 <field name="category"/>
                 <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                 <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
             </search>
         </field>
     </record>
 
     <record id="action_transport_fee_type" model="ir.actions.act_window">
         <field name="name">Fee Types</field>
         <field name="res_model">transport.fee.type</field>
         <field name="view_mode">list,form</field>
         <field name="search_view_id" ref="view_transport_fee_type_search"/>
     </record>
 
     <!-- ============================================================
          Rate Base - Tree + Form + Search
          ============================================================ -->
     <record id="view_transport_rate_base_tree" model="ir.ui.view">
         <field name="name">transport.rate.base.tree</field>
         <field name="model">transport.rate.base</field>
         <field name="arch" type="xml">
             <list string="Rate Bases" default_order="name">
                 <field name="name"/>
                 <field name="fee_type_id"/>
                 <field name="transport_type"/>
                 <field name="rate_type"/>
                 <field name="amount" widget="monetary"/>
                 <field name="valid_from"/>
                 <field name="valid_to"/>
                 <field name="active"/>
             </list>
         </field>
     </record>
 
     <record id="view_transport_rate_base_form" model="ir.ui.view">
         <field name="name">transport.rate.base.form</field>
         <field name="model">transport.rate.base</field>
         <field name="arch" type="xml">
             <form string="Rate Base">
                 <sheet>
                     <group>
                         <group>
                             <field name="name"/>
                             <field name="fee_type_id" options="{'no_create': True}"/>
                             <field name="transport_type"/>
                             <field name="rate_type"/>
                         </group>
                         <group>
                             <field name="amount" widget="monetary"/>
                             <field name="currency_id"/>
                             <field name="valid_from"/>
                             <field name="valid_to"/>
                         </group>
                     </group>
                     <group>
                         <field name="notes"/>
                     </group>
                 </sheet>
             </form>
         </field>
     </record>
 
     <record id="view_transport_rate_base_search" model="ir.ui.view">
         <field name="name">transport.rate.base.search</field>
         <field name="model">transport.rate.base</field>
         <field name="arch" type="xml">
             <search>
                 <field name="name"/>
                 <field name="fee_type_id"/>
                 <field name="transport_type"/>
                 <field name="rate_type"/>
                 <separator/>
                 <filter string="Active" name="active" domain="[('active', '=', True)]"/>
             </search>
         </field>
     </record>
 
     <record id="action_transport_rate_base" model="ir.actions.act_window">
         <field name="name">Rate Bases</field>
         <field name="res_model">transport.rate.base</field>
         <field name="view_mode">list,form</field>
         <field name="search_view_id" ref="view_transport_rate_base_search"/>
     </record>
 
     <!-- ============================================================
          Fee Line - Tree + Search (read-only view, created via quote/order)
          ============================================================ -->
     <record id="view_transport_fee_line_tree" model="ir.ui.view">
         <field name="name">transport.fee.line.tree</field>
         <field name="model">transport.fee.line</field>
         <field name="arch" type="xml">
             <list string="Fee Lines" default_order="id desc">
                 <field name="fee_type_id"/>
                 <field name="source_type" widget="badge"
                        decoration-info="source_type == 'commercial'"
                        decoration-success="source_type == 'plan_driven'"/>
                 <field name="quantity"/>
                 <field name="unit_amount" widget="monetary"/>
                 <field name="total_amount" widget="monetary" sum="Total"/>
                 <field name="source_quote_id" optional="show"/>
                 <field name="source_order_id" optional="show"/>
                 <field name="description" optional="show"/>
             </list>
         </field>
     </record>
 
     <record id="view_transport_fee_line_search" model="ir.ui.view">
         <field name="name">transport.fee.line.search</field>
         <field name="model">transport.fee.line</field>
         <field name="arch" type="xml">
             <search>
                 <field name="fee_type_id"/>
                 <field name="description"/>
                 <separator/>
                 <filter string="Plan-Driven" name="plan" domain="[('source_type', '=', 'plan_driven')]"/>
                 <filter string="Commercial" name="commercial" domain="[('source_type', '=', 'commercial')]"/>
                 <group expand="0" string="Group By">
                     <filter string="Source Type" name="group_source" context="{'group_by': 'source_type'}"/>
                     <filter string="Fee Type" name="group_fee" context="{'group_by': 'fee_type_id'}"/>
                 </group>
             </search>
         </field>
     </record>
 
     <record id="action_transport_fee_line" model="ir.actions.act_window">
         <field name="name">Fee Lines</field>
         <field name="res_model">transport.fee.line</field>
         <field name="view_mode">list,form</field>
         <field name="search_view_id" ref="view_transport_fee_line_search"/>
     </record>
 
 </odoo>
