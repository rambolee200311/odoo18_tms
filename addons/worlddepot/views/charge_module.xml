<odoo>
    <data>
        <!-- Tree View for Charge Module -->
        <record id="view_world_depot_charge_module_tree" model="ir.ui.view">
            <field name="name">charge.module.tree</field>
            <field name="model">world.depot.charge.module</field>
            <field name="arch" type="xml">
                <list string="Charge Modules">
                    <field name="name"/>
                    <field name="type"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Form View for Charge Module -->
        <record id="view_world_depot_charge_module_form" model="ir.ui.view">
            <field name="name">charge.module.form</field>
            <field name="model">world.depot.charge.module</field>
            <field name="arch" type="xml">
                <form string="Charge Module">
                    <header>
                        <button name="action_activate" type="object" string="Activate" class="btn-primary" invisible="state!='draft'"/>
                        <button name="action_deactivate" type="object" string="Deactivate" class="btn-primary" invisible="state!='active'"/>
                        <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" invisible="state!='draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,active"/>
                        <widget name="web_ribbon" title="CANCEL" bg_color="bg-danger" invisible="state!='cancel'"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                Charge Module
                            </h1>
                        </div> 
                        <group col="2">
                            <field name="name"/>
                            <field name="type"/>
                            <field name="description"/>
                        </group>                       
                        <notebook>
                            <page string="Items">
                                <field name="charge_item_ids">
                                    <list editable="bottom">
                                        <field name="charge_item_id"/>
                                        <field name="quantity"/>
                                        <field name="charge_unit_name" readonly="1"/>
                                        <field name="charge_unit_id"/>
                                        <field name="unit_price"/>
                                        <field name="amount" readonly="1"/>
                                    </list>
                                </field>
                            </page>                            
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search View for Charge Module -->
        <record id="view_world_depot_charge_module_search" model="ir.ui.view">
            <field name="name">charge.module.search</field>
            <field name="model">world.depot.charge.module</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="state"/>
                </search>
            </field>
        </record>

        <!-- Action for Charge Module -->
        <record id="action_world_depot_charge_module" model="ir.actions.act_window">
            <field name="name">Charge Modules</field>
            <field name="res_model">world.depot.charge.module</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>