<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- operation.workbench.card 看板视图 -->
    <record id="view_operation_workbench_card_kanban" model="ir.ui.view">
        <field name="name">operation.workbench.card.kanban</field>
        <field name="model">operation.workbench.card</field>
        <field name="arch" type="xml">
                <kanban default_group_by="lane_id" js_class="workbench_kanban" class="wd_iffm_kanban"
