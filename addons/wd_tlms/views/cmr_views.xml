<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tlmp_cmr_tree" model="ir.ui.view">
        <field name="name">tlmp.cmr.tree</field>
        <field name="model">tlmp.cmr</field>
        <field name="arch" type="xml">
            <list string="CMR Waybills" multi_edit="1">
                <field name="cmr_number"/>
                <field name="name"/>
                <field name="order_id"/>
                <field name="sender_id"/>
                <field name="consignee_id"/>
                <field name="carrier_id"/>
                <field name="packages_count" optional="hide"/>
                <field name="gross_weight" optional="hide"/>
                <field name="state" widget="badge" decoration-success="state == 'signed'" decoration-info="state == 'in_transit'" decoration-warning="state == 'printed'"/>
                <field name="pickup_datetime" optional="hide"/>
                <field name="delivery_datetime" optional="hide"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_tlmp_cmr_form" model="ir.ui.view">
        <field name="name">tlmp.cmr.form</field>
        <field name="model">tlmp.cmr</field>
        <field name="arch" type="xml">
            <form string="CMR Waybill">
                <header>
                    <field name="state" widget="badge" decoration-success="state == 'signed'" decoration-info="state == 'in_transit'" decoration-warning="state == 'printed'"/>
                    <button name="action_print_cmr" type="object" string="Print CMR"
                            class="btn-primary"
                            invisible="state not in ('signed', 'archived')"/>
                    <button name="action_confirm_signature" type="object" string="Confirm Signature"
                            invisible="state == 'in_transit'"/>
                    <button name="action_archive" type="object" string="Archive"
                            invisible="state == 'archived'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="cmr_number" placeholder="CMR Number" class="oe_inline"/>
                        </h1>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="order_id" options="{'no_create': True}"/>
                                <field name="copy_number"/>
                            </group>
                            <group>
                                <field name="dock_number" placeholder="Optional dock no."/>
                            </group>
                        </group>
                    </div>

                    <notebook>
                        <!-- Tab 1: Parties -->
                        <page string="Parties">
                            <group string="Sender / Consignee">
                                <group>
                                    <field name="sender_id" options="{'no_create': True}"/>
                                    <field name="place_of_taking_over"/>
                                </group>
                                <group>
                                    <field name="consignee_id" options="{'no_create': True}"/>
                                    <field name="place_of_delivery"/>
                                </group>
                            </group>
                            <group string="Carrier / Transit">
                                <group>
                                    <field name="carrier_id" options="{'no_create': True}"/>
                                    <field name="vehicle_reg_no"/>
                                </group>
                                <group>
                                    <field name="transit_countries"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 2: Cargo Lines -->
                        <page string="Cargo Lines">
                            <group>
                                <field name="packages_count" class="oe_inline"/>
                                <field name="gross_weight" class="oe_inline"/>
                            </group>
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom" multi_edit="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="commodity"/>
                                    <field name="sku"/>
                                    <field name="qty"/>
                                    <field name="gross_weight_per_unit"/>
                                    <field name="gross_weight"/>
                                    <field name="points"/>
                                </list>
                            </field>
                            <group>
                                <field name="cargo_description" placeholder="Cargo description (manual override if needed)"/>
                                <field name="container_no"/>
                                <field name="seal_no"/>
                            </group>
                        </page>

                        <!-- Tab 3: Vehicle & ADR -->
                        <page string="Vehicle &amp; ADR" groups="wd_tlms.group_tlm_manager">
                            <group string="Vehicle">
                                <field name="vehicle_reg_no"/>
                            </group>
                            <group string="ADR (from Transport Order)" colspan="2">
                                <group>
                                    <field name="has_dangerous_goods"/>
                                    <field name="adr_class"/>
                                </group>
                                <group>
                                    <field name="adr_un_number"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 4: Financial -->
                        <page string="Financial">
                            <group>
                                <group>
                                    <field name="freight_charges"/>
                                    <field name="currency_id"/>
                                </group>
                                <group>
                                    <field name="additional_charges"/>
                                </group>
                            </group>
                        </page>

                        <!-- Tab 5: Remarks -->
                        <page string="Remarks">
                            <group>
                                <field name="sender_remarks"/>
                                <field name="carrier_remarks"/>
                                <field name="sender_instructions"/>
                                <field name="documents_attached"/>
                            </group>
                            <group string="Dates">
                                <field name="pickup_datetime"/>
                                <field name="delivery_datetime"/>
                            </group>
                        </page>

                        <!-- Tab 6: Signature & POD -->
                        <page string="Signature">
                            <group>
                                <field name="damage_description"/>
                            </group>
                            <group string="Signature">
                                <group>
                                    <field name="signed_by"/>
                                    <field name="signed_date"/>
                                </group>
                                <group>
                                    <field name="signature_image" widget="image"/>
                                    <field name="signed_cmr_pdf" filename="cmr_number" widget="binary"/>
                                    <field name="is_pod_confirmed"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tlmp_cmr_search" model="ir.ui.view">
        <field name="name">tlmp.cmr.search</field>
        <field name="model">tlmp.cmr</field>
        <field name="arch" type="xml">
            <search>
                <field name="cmr_number"/>
                <field name="name"/>
                <field name="order_id"/>
                <field name="sender_id"/>
                <field name="consignee_id"/>
                <field name="carrier_id"/>
                <field name="vehicle_reg_no"/>
                <filter string="Draft" name="state_draft" domain="[('state','=','draft')]"/>
                <filter string="Printed" name="state_printed" domain="[('state','=','printed')]"/>
                <filter string="In Transit" name="state_transit" domain="[('state','=','in_transit')]"/>
                <filter string="Signed" name="state_signed" domain="[('state','=','signed')]"/>
                <filter string="Archived" name="state_archived" domain="[('state','=','archived')]"/>
                <separator/>
                <filter string="My Orders" name="my_orders" domain="[('order_id.carrier_id','=',uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Carrier" name="group_carrier" context="{'group_by':'carrier_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tlmp_cmr" model="ir.actions.act_window">
        <field name="name">CMR Waybills</field>
        <field name="res_model">tlmp.cmr</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Create and manage CMR waybills for transport orders.</p>
            <p>Use <b>Create from Order</b> to pre-fill sender/consignee information from a transport order.</p>
        </field>
    </record>

    <record id="action_tlmp_cmr_from_order" model="ir.actions.act_window">
        <field name="name">New CMR from Order</field>
        <field name="res_model">tlmp.cmr</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_tlmp_transport_order"/>
        <field name="binding_view_types">form</field>
        <field name="context">{'default_order_id': active_id}</field>
    </record>
</odoo>
