    <!-- Action -->
    <record id="action_charge_quotation" model="ir.actions.act_window">
        <field name="name">Quotations</field>
        <field name="res_model">charge.quotation</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_charge_quotation_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first quotation.</p>
        </field>
    </record>

    <!-- Menus -->

