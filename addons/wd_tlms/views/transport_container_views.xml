<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tlmp_transport_container_tree" model="ir.ui.view">
        <field name="name">tlmp.transport.container.tree</field>
        <field name="model">tlmp.transport.container</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="container_type"/>
                <field name="container_master_id" optional="show"/>
                <field name="needs_swap"/>
                <field name="swap_location_id"/>
            </list>
        </field>
    </record>

    <record id="view_tlmp_transport_container_form" model="ir.ui.view">
        <field name="name">tlmp.transport.container.form</field>
        <field name="model">tlmp.transport.container</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group string="Container Info">
                        <field name="name"/>
                        <field name="container_type"/>
                        <field name="container_master_id" options="{'no_create': True}"/>
                        <field name="seal_number"/>
                        <field name="cargo_weight_kg"/>
                    </group>
                    <group string="Swap / Return">
                        <field name="needs_swap"/>
                        <field name="swap_location_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tlmp_transport_container_search" model="ir.ui.view">
        <field name="name">tlmp.transport.container.search</field>
        <field name="model">tlmp.transport.container</field>
        <field name="arch" type="xml">
            <search/>
        </field>
    </record>

    <record id="action_tlmp_container" model="ir.actions.act_window">
        <field name="name"></field>
        <field name="res_model">tlmp.transport.container</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
