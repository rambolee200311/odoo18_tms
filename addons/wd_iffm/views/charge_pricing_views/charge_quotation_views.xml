<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree -->
    <record id="view_charge_quotation_tree" model="ir.ui.view">
        <field name="name">charge.quotation.tree</field>
        <field name="model">charge.quotation</field>
        <field name="arch" type="xml">
            <list>
                <field name="alias_name"/>
                <field name="name"/>
                <field name="state"/>
                <field name="is_active"/>
                <field name="effective_from"/>
                <field name="effective_to"/>
                <field name="currency_id"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_charge_quotation_form" model="ir.ui.view">
        <field name="name">charge.quotation.form</field>
        <field name="model">charge.quotation</field>
        <field name="arch" type="xml">
            <form class="wd_iffm_required_highlight">
                <header>
                    <button name="action_set_active" type="object" string="Activate"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
<!--                    <button name="action_export_by_category" string="Export" type="object" class="btn-secondary"/>-->
                    <button name="action_set_expired" type="object" string="Expire"
                            invisible="state != 'active'"/>
                    <button name="action_set_draft" type="object" string="Set Draft"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,expired"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="alias_name" readonly="state != 'draft'"/>
                            <field name="name" readonly="1"/>
                            <field name="currency_id" required="1"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="date" required="1" readonly="state != 'draft'"/>
                            <field name="effective_from" required="1" readonly="state != 'draft'"/>
                            <field name="effective_to" readonly="state != 'draft'"/>
                            <field name="remark"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- THC Handling -->
                        <page string="THC Handling">
                            <group>
                                <button name="%(action_charge_quotation_add_wizard)d"
                                        string="Batch Add"
                                        type="action"
                                        class="btn-secondary"
                                        invisible="state != 'draft'"
                                        context="{'default_quotation_id': id, 'default_tab_category': 'thc'}"/>
                            </group>

                            <field name="quotation_thc_lines" readonly="state != 'draft'"
                                   context="{'default_tab_category': 'thc'}">
                                <list editable="bottom">
                                    <field name="charge_item_id" required="1"
                                           options="{'no_create': True, 'no_open': True}"
                                           domain="[('tab_category', '=', context.get('default_tab_category')),('is_leaf','=',True)]"/>
                                    <field name="tab_category" column_invisible="1"/>
                                    <field name="is_fixed_fee"/>
                                    <field name="unit_price"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>

                        <!-- Customs Formalities -->
                        <page string="Customs Formalities">
                            <group>
                                <button name="%(action_charge_quotation_add_wizard)d"
                                        string="Batch Add"
                                        type="action"
                                        class="btn-secondary"
                                        invisible="state != 'draft'"
                                        context="{'default_quotation_id': id, 'default_tab_category': 'customs'}"/>
                            </group>

                            <field name="quotation_customs_lines" readonly="state != 'draft'"
                                   context="{'default_tab_category': 'customs'}">
                                <list editable="bottom">
                                    <field name="charge_item_id" required="1"
                                           options="{'no_create': True, 'no_open': True}"
                                           domain="[('tab_category', '=', context.get('default_tab_category')),('is_leaf','=',True)]"/>
                                    <field name="tab_category" column_invisible="1"/>
                                    <field name="is_fixed_fee"/>
                                    <field name="unit_price"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>

