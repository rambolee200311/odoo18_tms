<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 首页动作 - 复用现有的提单表单视图 -->
    <record id="action_home_page" model="ir.actions.act_window">
        <field name="name">首页</field>
        <field name="res_model">world.depot.waybill</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="wd_iffm.view_world_depot_waybill_form"/>
        <field name="target">current</field>
    </record>

    <!-- 进口提单看板动作 -->
    <record id="action_import_bill_kanban" model="ir.actions.act_window">
        <field name="name">进口提单看板</field>
        <field name="res_model">world.depot.waybill</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('state', '!=', 'cancel')]</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('wd_iffm.view_waybill_kanban_level1')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('wd_iffm.view_world_depot_waybill_tree')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('wd_iffm.view_world_depot_waybill_form')})
            ]"/>
        <field name="context">{'search_default_group_by_state': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                暂无进口提单数据
            </p>
            <p>
                点击"创建"按钮添加新的进口提单
            </p>
        </field>
    </record>
    
