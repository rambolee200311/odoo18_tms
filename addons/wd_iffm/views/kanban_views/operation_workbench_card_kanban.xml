                            <div t-if="record.lane_code.raw_value == 'waybill'" class="o_kanban_statusbar mb-1">
                                <field name="waybill_state" widget="statusbar" readonly="1"/>
                            </div>

                            <!-- 换单-进度状态条 -->
                            <div t-if="record.lane_code.raw_value == 'handover'" class="o_kanban_statusbar mb-1">
                                <field name="handover_state" statusbar_visible="open,paid,released,close" widget="statusbar" readonly="1" />
                            </div>

                             <!-- 清关-进度状态条 -->
                             <div t-if="record.lane_code.raw_value == 'clearance'" class="o_kanban_statusbar mb-1">
