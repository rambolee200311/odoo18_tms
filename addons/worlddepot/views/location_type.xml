<odoo>
    <data>
        <!-- Form View -->
        <record id="view_stock_location_type_form" model="ir.ui.view">
            <field name="name">stock.location.type.form</field>
            <field name="model">stock.location.type</field>
            <field name="arch" type="xml">
                <form string="Location Type">
                    <sheet>            
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="description"/>
                        </group>
                    </sheet>       
                </form>
            </field>
        </record>
        <!-- List View-->
        <record id="view_stock_location_type_tree" model="ir.ui.view">
            <field name="name">stock.location.type.tree</field>
            <field name="model">stock.location.type</field>
            <field name="arch" type="xml">
                <list string="Locations">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="description"/>
                </list>
            </field>
        </record>
        <!-- Action -->
        <record id="action_stock_location_type" model="ir.actions.act_window">
            <field name="name">Location Types</field>
            <field name="res_model">stock.location.type</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>