<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tlmp_pricing_rule_tree" model="ir.ui.view">
        <field name="name">tlmp.pricing.rule.tree</field>
        <field name="model">tlmp.pricing.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_tlmp_pricing_rule_form" model="ir.ui.view">
        <field name="name">tlmp.pricing.rule.form</field>
        <field name="model">tlmp.pricing.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tlmp_pricing_rule_search" model="ir.ui.view">
        <field name="name">tlmp.pricing.rule.search</field>
        <field name="model">tlmp.pricing.rule</field>
        <field name="arch" type="xml">
            <search/>
        </field>
    </record>

    <record id="action_tlmp_pricing_rule" model="ir.actions.act_window">
        <field name="name">Pricing Rules</field>
        <field name="res_model">tlmp.pricing.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
