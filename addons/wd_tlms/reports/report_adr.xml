<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <report id="report_adr" string="ADR Transport Document" model="tlmp.transport.order"
        report_type="qweb-pdf"
        file="wd_tlms.report_adr_document"
        name="wd_tlms.report_adr_document"/>
    <template id="report_adr_document">
        <t t-call="web.html_container">
            <div class="page"><h2>ADR Transport Document</h2>
            <p>UN No: <span t-field="o.adr_un_number"/></p>
            <p>Class: <span t-field="o.adr_class"/></p></div>
        </t>
    </template>
</odoo>