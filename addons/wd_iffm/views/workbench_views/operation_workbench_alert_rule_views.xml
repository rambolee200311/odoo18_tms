<odoo>
    <record id="view_operation_workbench_alert_rule_list" model="ir.ui.view">
        <field name="name">operation.workbench.alert.rule.list</field>
        <field name="model">operation.workbench.alert.rule</field>
        <field name="arch" type="xml">
            <list default_order="id desc">
                <field name="name" width="220px"/>
                <field name="arrival_near_hours" width="140px"/>
                <field name="handover_available_days" width="180px"/>
                <field name="handover_near_hours" width="160px"/>
                <field name="clearance_available_days" width="180px"/>
                <field name="clearance_near_hours" width="160px"/>
                <field name="active" width="80px"/>
            </list>
        </field>
    </record>

    <record id="view_operation_workbench_alert_rule_form" model="ir.ui.view">
        <field name="name">operation.workbench.alert.rule.form</field>
        <field name="model">operation.workbench.alert.rule</field>
        <field name="arch" type="xml">
            <form duplicate="0">
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="1"/>

                            <field name="active"/>
                        </group>
                        <group>
                            <field name="arrival_near_hours" required="1"/>
                            <field name="handover_available_days" required="1"/>
                            <field name="handover_near_hours" required="1"/>
                            <field name="clearance_available_days" required="1"/>
                            <field name="clearance_near_hours" required="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_operation_workbench_alert_rule" model="ir.actions.act_window">
        <field name="name">Workbench Alert Rule</field>
        <field name="res_model">operation.workbench.alert.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_operation_workbench_alert_rule"
              name="Workbench Alert Rule"
              parent="menu_wd_base_config"
              action="action_operation_workbench_alert_rule"
              sequence="991"/>
</odoo>