<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tlmp_cmr_coordinate_tree" model="ir.ui.view">
        <field name="name">tlmp.cmr.coordinate.tree</field>
        <field name="model">tlmp.cmr.coordinate</field>
        <field name="arch" type="xml">
            <list string="CMR Coordinates" multi_edit="1" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="field_identifier"/>
                <field name="section"/>
                <field name="x_mm"/>
                <field name="y_mm"/>
                <field name="font_size"/>
                <field name="alignment"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tlmp_cmr_coordinate_form" model="ir.ui.view">
        <field name="name">tlmp.cmr.coordinate.form</field>
        <field name="model">tlmp.cmr.coordinate</field>
        <field name="arch" type="xml">
            <form string="CMR Coordinate">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="field_identifier"/>
                            <field name="section"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="x_mm"/>
                            <field name="y_mm"/>
                            <field name="font_size"/>
                            <field name="alignment"/>
                        </group>
                    </group>
                    <group>
                        <field name="max_length"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tlmp_cmr_coordinate_search" model="ir.ui.view">
        <field name="name">tlmp.cmr.coordinate.search</field>
        <field name="model">tlmp.cmr.coordinate</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="field_identifier"/>
                <field name="section"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active','=',False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Section" name="group_section" context="{'group_by':'section'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tlmp_cmr_coordinate" model="ir.actions.act_window">
        <field name="name">CMR Coordinates</field>
        <field name="res_model">tlmp.cmr.coordinate</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
