<odoo>
    <record id="account_move_form_inherit_bank_proof" model="ir.ui.view">
        <field name="name">account.move.form.inherit.bank.proof</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="waybill_bill_number" readonly="1" invisible="move_type != 'in_invoice'"/>
                <field name="bank_proof_attachment_ids"
                       widget="many2many_binary"
                       string="Bank Proof (Water Slip)"
                       invisible="move_type != 'in_invoice'"/>
            </xpath>

            <xpath expr="//header//button[@name='button_draft']" position="after">
                <button name="action_confirm_paid_sync_operation"
                        type="object"
                        string="Confirm Paid"
                        class="btn-success"
                        invisible="move_type != 'in_invoice'
                               or payment_state != 'paid'
                               or not bank_proof_attachment_ids"/>
                <!--            <button name="action_push_customer_invoice_files_to_period"-->
                <!--            type="object"-->
                <!--            string="Push Files To Statement Period"-->
                <!--            class="btn-primary"-->
                <!--            invisible="move_type != 'out_invoice' or not attachment_ids"/>-->
            </xpath>

        </field>
    </record>
    <record id="view_in_invoice_bill_list_inherit_waybill_bill_number" model="ir.ui.view">
        <field name="name">account.move.in.invoice.bill.list.inherit.waybill.bill.number</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_origin']" position="after">
                <field name="waybill_bill_number" optional="show"/>
            </xpath>
        </field>
    </record>


</odoo>