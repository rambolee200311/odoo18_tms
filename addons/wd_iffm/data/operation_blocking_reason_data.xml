<odoo noupdate="1">
    <record id="operation_blocking_reason_01" model="operation.blocking.reason">
        <field name="name">Customer information not provided</field>
        <field name="short_name">Cust Info Missing</field>
    </record>

    <record id="operation_blocking_reason_02" model="operation.blocking.reason">
        <field name="name">Fees unpaid / pending confirmation</field>
        <field name="short_name">Fee Unpaid</field>
    </record>

    <record id="operation_blocking_reason_03" model="operation.blocking.reason">
        <field name="name">Incomplete documents (invoice, packing list, contract, etc.)</field>
        <field name="short_name">Docs Incomplete</field>
    </record>

    <record id="operation_blocking_reason_04" model="operation.blocking.reason">
