<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action: 进口货代首页 -->
    <record id="action_wd_iffm_workbench" model="ir.actions.client">
        <field name="name">进口货代首页</field>
        <field name="tag">wd_iffm_workbench</field>
        <field name="target">current</field>
    </record>

    <!-- Calendar视图: 按ETA日期显示提单 -->
    <record id="view_waybill_calendar" model="ir.ui.view">
        <field name="name">world.depot.waybill.calendar</field>
        <field name="model">world.depot.waybill</field>
        <field name="arch" type="xml">
            <calendar date_start="eta" string="预计到港时间" mode="month">
                <field name="bl_number"/>
                <field name="hbl_number"/>
                <field name="obl_number"/>
                <field name="state"/>
                <field name="project"/>
            </calendar>
        </field>
    </record>

    <!-- 菜单结构 -->
    <menuitem id="menu_wd_iffm_root" name="进口货代管理" sequence="10"/>

