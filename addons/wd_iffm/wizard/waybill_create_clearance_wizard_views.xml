<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_waybill_create_clearance_wizard_form" model="ir.ui.view">
        <field name="name">waybill.create.clearance.wizard.form</field>
        <field name="model">waybill.create.clearance.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Containers for Clearance">
                <group>
                    <field name="waybill_id"/>
                    <field name="container_ids"
                           domain="[('id', 'in', available_container_ids)]"
                           widget="many2many_tags"
                           options="{'no_create': True, 'no_open': True}"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Generate Clearance" class="btn-primary" invisible="from_workbench == True"/>
                    <button name="action_confirm_workbench"
                            type="object"
                            string="Create Main Clearance"
                            class="btn-primary"
                            invisible="from_workbench == False"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
